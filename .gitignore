# Ignore Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment variables (NEVER commit)
.env

# Sessions and sensitive data
sessions/
*.session
*.session-journal

# Logs
logs/
*.log

# Downloaded files
tmp/
temp/
downloads/

# Cookies
cookies.txt

# Docker volumes
mongo-data/
redis-data/

# Local workspace config
bot/.env.local

# Pytest cache
.pytest_cache/
